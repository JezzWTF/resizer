<Window x:Class="BatchResizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BatchResizer.ViewModels"
        xmlns:conv="clr-namespace:BatchResizer.Converters"
        xmlns:models="clr-namespace:BatchResizer.Models"
        Title="Batch Image Resizer"
        Icon="/icon.ico"
        Width="1100" Height="750" MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        AllowDrop="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Dark.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <conv:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>
            <conv:FileResultStatusToColorConverter x:Key="StatusToColor"/>
            <conv:FolderExistsToBrushConverter x:Key="FolderExistsToBrush"/>
            <conv:IntToVisibilityConverter x:Key="IntToVis"/>
            <conv:ResizeModeToStringConverter x:Key="ResizeModeToStr"/>
            <conv:OutputModeToStringConverter x:Key="OutputModeToStr"/>
            <conv:OutputFormatToStringConverter x:Key="OutputFormatToStr"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="#252526" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x26A1;" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Batch Image Resizer" FontSize="18" FontWeight="SemiBold"
                               Foreground="#F0F0F0" VerticalAlignment="Center"/>
                    <TextBlock Text="by JezzWTF" FontSize="12" Foreground="#6A6A6A"
                               Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" MinWidth="360"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: Settings -->
            <ScrollViewer Grid.Column="0"
                          Background="#252526"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="16,12,16,16">

                    <!-- Source Folders -->
                    <TextBlock Text="SOURCE FOLDERS" Style="{StaticResource SectionHeader}"/>
                    <Border x:Name="FolderDropBorder"
                            CornerRadius="4" MinHeight="120" MaxHeight="180" AllowDrop="True">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"      Value="#2D2D30"/>
                                <Setter Property="BorderBrush"     Value="#3F3F46"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDragOver}" Value="True">
                                        <Setter Property="Background"      Value="#1A2D3D"/>
                                        <Setter Property="BorderBrush"     Value="#0078D4"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <ListBox x:Name="FolderListBox"
                                     ItemsSource="{Binding SourceFolders}"
                                     SelectedItem="{Binding SelectedFolder}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     AllowDrop="True">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:FolderItemViewModel}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#x1F4C1;" Margin="0,0,8,0"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Path}" FontSize="12"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{Binding Exists, Converter={StaticResource FolderExistsToBrush}}"/>
                                                <TextBlock Text="{Binding CountLabel}" FontSize="10"
                                                           Foreground="#7A7A7A" Margin="0,1,0,0"
                                                           Visibility="{Binding ImageCount, Converter={StaticResource IntToVis}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Text="Drop folders here or click Add Folder below"
                                       Foreground="#555555" FontSize="12" TextAlignment="Center"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SourceFolders.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <WrapPanel Margin="0,6,0,0">
                        <Grid Margin="0,0,6,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="22"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="+ Add Folder"
                                    Command="{Binding AddFolderCommand}"
                                    Style="{StaticResource SecondaryButton}" Padding="12,6"/>
                            <Button Grid.Column="1" Content="▾" FontSize="10"
                                    Style="{StaticResource SecondaryButton}" Padding="0,6"
                                    x:Name="RecentFoldersDropdownButton"
                                    Click="OnRecentFoldersDropdownClick"/>
                        </Grid>
                        <Button Content="Remove" Command="{Binding RemoveFolderCommand}"
                                Style="{StaticResource SecondaryButton}" Padding="12,6" Margin="0,0,6,0"/>
                        <Button Content="Clear All" Command="{Binding ClearFoldersCommand}"
                                Style="{StaticResource SecondaryButton}" Padding="12,6" Margin="0,0,6,0"/>
                        <Button Content="Scan" Command="{Binding ScanFoldersCommand}"
                                Style="{StaticResource SecondaryButton}" Padding="12,6"/>
                    </WrapPanel>

                    <CheckBox Content="Include subfolders (recursive)"
                              IsChecked="{Binding Recursive}"
                              Margin="0,10,0,0"/>

                    <Separator Margin="0,12"/>

                    <!-- File Type Filters -->
                    <TextBlock Text="FILE TYPES" Style="{StaticResource SectionHeader}"/>
                    <WrapPanel Orientation="Horizontal">
                        <CheckBox Content="JPEG" IsChecked="{Binding IncludeJpeg}" Margin="0,0,14,6"/>
                        <CheckBox Content="PNG"  IsChecked="{Binding IncludePng}"  Margin="0,0,14,6"/>
                        <CheckBox Content="WebP" IsChecked="{Binding IncludeWebP}" Margin="0,0,14,6"/>
                        <CheckBox Content="BMP"  IsChecked="{Binding IncludeBmp}"  Margin="0,0,14,6"/>
                        <CheckBox Content="TIFF" IsChecked="{Binding IncludeTiff}" Margin="0,0,14,6"/>
                        <CheckBox Content="GIF"  IsChecked="{Binding IncludeGif}"  Margin="0,0,14,6"/>
                    </WrapPanel>

                    <Separator Margin="0,12"/>

                    <!-- Resize Settings -->
                    <TextBlock Text="RESIZE SETTINGS" Style="{StaticResource SectionHeader}"/>

                    <TextBlock Text="Preset" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Presets}"
                              SelectedItem="{Binding SelectedPreset}"
                              Margin="0,0,0,8">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Resize Mode" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding ResizeModes}"
                              SelectedItem="{Binding ResizeMode}"
                              Margin="0,0,0,8">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource ResizeModeToStr}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Width/Height (hidden in Percentage mode) -->
                    <Grid Margin="0,0,0,8">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPercentageMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource FieldLabel}">
                                        <Setter Property="Text" Value="Width (px)"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSingleDimensionMode}" Value="True">
                                                <Setter Property="Text" Value="Max Size (px)"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox Text="{Binding TargetWidth, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSingleDimensionMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Height (px)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding TargetHeight, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Percentage slider -->
                    <StackPanel Visibility="{Binding IsPercentageMode, Converter={StaticResource BoolToVis}}"
                                Margin="0,0,0,8">
                        <Grid>
                            <TextBlock Text="Scale Percentage" Style="{StaticResource FieldLabel}"/>
                            <TextBlock HorizontalAlignment="Right" Foreground="#9D9D9D" FontSize="11"
                                       Text="{Binding Percentage, StringFormat={}{0:F0}%}"/>
                        </Grid>
                        <Slider Minimum="1" Maximum="200" Value="{Binding Percentage}"
                                IsSnapToTickEnabled="False"/>
                    </StackPanel>

                    <Separator Margin="0,12"/>

                    <!-- Output Settings -->
                    <TextBlock Text="OUTPUT SETTINGS" Style="{StaticResource SectionHeader}"/>

                    <TextBlock Text="Output Mode" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding OutputModes}"
                              SelectedItem="{Binding OutputMode}"
                              Margin="0,0,0,8">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource OutputModeToStr}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <StackPanel Visibility="{Binding ShowSubfolderName, Converter={StaticResource BoolToVis}}"
                                Margin="0,0,0,8">
                        <TextBlock Text="Subfolder Name" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding SubfolderName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding ShowCustomOutputFolder, Converter={StaticResource BoolToVis}}"
                                Margin="0,0,0,8">
                        <TextBlock Text="Output Folder" Style="{StaticResource FieldLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding CustomOutputFolder, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,6,0"/>
                            <Button Grid.Column="1" Content="Browse"
                                    Command="{Binding BrowseOutputFolderCommand}"
                                    Style="{StaticResource SecondaryButton}" Padding="10,6"/>
                        </Grid>
                    </StackPanel>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Filename Prefix" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding FilePrefix, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Filename Suffix" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding FileSuffix, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <CheckBox Content="Skip if output file already exists"
                              IsChecked="{Binding SkipExisting}"
                              IsEnabled="{Binding SkipExistingEnabled}"
                              Margin="0,0,0,6"/>
                    <CheckBox Content="Skip images already smaller than target"
                              IsChecked="{Binding SkipSmallerThanTarget}"/>

                    <Separator Margin="0,12"/>

                    <!-- Metadata -->
                    <TextBlock Text="METADATA" Style="{StaticResource SectionHeader}"/>

                    <CheckBox Content="Preserve original file timestamps"
                              IsChecked="{Binding PreserveTimestamps}"
                              Margin="0,0,0,8"/>

                    <TextBlock Text="Image Metadata" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding MetadataModes}"
                              SelectedItem="{Binding MetadataMode}"
                              Margin="0,0,0,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding}" Value="PreserveAll">
                                                    <Setter Property="Text" Value="Preserve all (EXIF, XMP, ICC)"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="ExifOnly">
                                                    <Setter Property="Text" Value="EXIF only (strip XMP &amp; ICC)"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="StripAll">
                                                    <Setter Property="Text" Value="Strip all metadata"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Separator Margin="0,12"/>

                    <!-- Format and Quality -->
                    <TextBlock Text="FORMAT &amp; QUALITY" Style="{StaticResource SectionHeader}"/>

                    <TextBlock Text="Output Format" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding OutputFormats}"
                              SelectedItem="{Binding OutputFormat}"
                              Margin="0,0,0,8">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource OutputFormatToStr}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <StackPanel Visibility="{Binding ShowJpegQuality, Converter={StaticResource BoolToVis}}"
                                Margin="0,0,0,8">
                        <Grid>
                            <TextBlock Text="JPEG Quality" Style="{StaticResource FieldLabel}"/>
                            <TextBlock HorizontalAlignment="Right" Foreground="#9D9D9D" FontSize="11"
                                       Text="{Binding JpegQuality}"/>
                        </Grid>
                        <Slider Minimum="1" Maximum="100" Value="{Binding JpegQuality}"
                                IsSnapToTickEnabled="False"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding ShowWebPQuality, Converter={StaticResource BoolToVis}}"
                                Margin="0,0,0,8">
                        <Grid>
                            <TextBlock Text="WebP Quality" Style="{StaticResource FieldLabel}"/>
                            <TextBlock HorizontalAlignment="Right" Foreground="#9D9D9D" FontSize="11"
                                       Text="{Binding WebPQuality}"/>
                        </Grid>
                        <Slider Minimum="1" Maximum="100" Value="{Binding WebPQuality}"
                                IsSnapToTickEnabled="False"/>
                    </StackPanel>

                    <Separator Margin="0,12"/>

                    <!-- Action Buttons -->
                    <Button Content="START RESIZING"
                            Command="{Binding StartResizingCommand}"
                            FontSize="15" FontWeight="SemiBold"
                            Padding="0,14"
                            Visibility="{Binding IsIdle, Converter={StaticResource BoolToVis}}"/>

                    <Button Content="CANCEL"
                            Command="{Binding CancelProcessingCommand}"
                            Style="{StaticResource DangerButton}"
                            FontSize="15" FontWeight="SemiBold"
                            Padding="0,14"
                            Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"/>

                </StackPanel>
            </ScrollViewer>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" Background="#3F3F46"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- RIGHT PANEL: Progress and Log -->
            <Grid Grid.Column="2" Background="#1E1E1E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Stats -->
                <Border Grid.Row="0" Background="#252526" BorderBrush="#3F3F46"
                        BorderThickness="0,0,0,1" Padding="20,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding ProgressTotal}" FontSize="28" FontWeight="Bold"
                                       Foreground="#F0F0F0" HorizontalAlignment="Center"/>
                            <TextBlock Text="Total" Foreground="#7A7A7A" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding ProgressProcessed}" FontSize="28" FontWeight="Bold"
                                       Foreground="#4CAF50" HorizontalAlignment="Center"/>
                            <TextBlock Text="Resized" Foreground="#7A7A7A" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding ProgressSkipped}" FontSize="28" FontWeight="Bold"
                                       Foreground="#9E9E9E" HorizontalAlignment="Center"/>
                            <TextBlock Text="Skipped" Foreground="#7A7A7A" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding ProgressErrors}" FontSize="28" FontWeight="Bold"
                                       Foreground="#F44336" HorizontalAlignment="Center"/>
                            <TextBlock Text="Errors" Foreground="#7A7A7A" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Progress bar -->
                <StackPanel Grid.Row="1" Margin="20,14,20,8"
                            Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}">
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding CurrentFile}" Foreground="#9D9D9D" FontSize="11"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="1" Foreground="#9D9D9D" FontSize="11" Margin="8,0"
                                   Text="{Binding ProcessingSpeed}"/>
                        <TextBlock Grid.Column="2" Foreground="#9D9D9D" FontSize="11"
                                   Text="{Binding ProcessingEta}"/>
                    </Grid>
                    <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Height="6"/>
                </StackPanel>

                <!-- Scanning indicator -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,14,20,8"
                            Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Scanning files..." Foreground="#9D9D9D" FontSize="12"/>
                </StackPanel>

                <!-- Log -->
                <Grid Grid.Row="2" Margin="20,8,20,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="LOG" Style="{StaticResource SectionHeader}" Margin="0"/>
                        <TextBlock HorizontalAlignment="Right" Foreground="#555555" FontSize="10"
                                   VerticalAlignment="Center"
                                   Text="{Binding Log.Count, StringFormat={}{0} entries}"/>
                    </Grid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Command="{Binding SetLogFilterCommand}"
                                CommandParameter="{x:Static models:LogFilter.All}"
                                Content="All" Padding="10,3" Margin="0,0,4,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFilterAll}" Value="True">
                                            <Setter Property="Background" Value="#0078D4"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding SetLogFilterCommand}"
                                CommandParameter="{x:Static models:LogFilter.Errors}"
                                Content="Errors" Padding="10,3" Margin="0,0,4,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFilterErrors}" Value="True">
                                            <Setter Property="Background" Value="#0078D4"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding SetLogFilterCommand}"
                                CommandParameter="{x:Static models:LogFilter.Skipped}"
                                Content="Skipped" Padding="10,3">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFilterSkipped}" Value="True">
                                            <Setter Property="Background" Value="#0078D4"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding LogView}"
                             Background="#1A1A1A"
                             BorderBrush="#2D2D30"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:LogEntryViewModel}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding StatusIcon}"
                                               Foreground="{Binding Status, Converter={StaticResource StatusToColor}}"
                                               FontSize="12" FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DisplayText}"
                                               FontSize="11"
                                               Foreground="{Binding Status, Converter={StaticResource StatusToColor}}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding FilePath}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="2"
                               Text="Processing results will appear here."
                               Foreground="#444444" FontSize="13" TextAlignment="Center"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Log.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#007ACC" Padding="16,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="White" FontSize="12"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</Window>
